{
  "info": {
    "name": "BOLA checks - sample",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Try to access other user's resource by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/badge/requests/{{otherUserId}}",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Should refuse with 403/404', function () {",
              "  pm.expect([403,404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}